# Configuração do Ambiente - Zauli's Coffee

# ========== SERVIDOR ==========
NODE_ENV=development
PORT=3000

# ========== EMAIL (Opcional) ==========
# Para enviar confirmações de pedido
EMAIL_SERVICE=gmail
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_aplicacao
EMAIL_FROM=noreply@zauliscoffee.com

# ========== WHATSAPP ==========
WHATSAPP_NUMBER=5511911245236
WHATSAPP_MESSAGE=Olá! Gostaria de mais informações sobre os cafés Zauli's

# ========== BANCO DE DADOS (Futuro) ==========
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=zaulis_coffee
# DB_USER=admin
# DB_PASSWORD=senha_segura

# ========== SEGURANÇA ==========
# Gere com: openssl rand -base64 32
SESSION_SECRET=sua_chave_secreta_aqui

# ========== LOGGING ==========
LOG_LEVEL=info
